{
  "schemaVersion": 1,
  "id": "${modId}",
  "version": "${modVersion}",
  "name": "${modName}",
  "description": "${modDescription}",
  "authors": ["${modAuthors}"],
  "contact": {
    "homepage": "${modDisplayURL}",
    "sources": "${modIssueTrackerURL}"
  },
  "license": "${modLicense}",
  "icon": "${modId}.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "${modGroup}.fabric.RenourishedDelightModFabric"
    ],
    "client": [
      "${modGroup}.fabric.client.RenourishedDelightModFabricClient"
    ]
  },
  "mixins": [
    "${modId}.common.mixins.json",
    "${modId}.fabric.mixins.json"
  ],
  "depends": {
    "java": ">=17",
    "fabric-api": "*",
    "fabricloader": ">=${fabricLoaderVersion}",
    "architectury": ">=${architecturyApiVersion}",
    "minecraft": "~${minecraftVersion}"
  }
}
